<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Diagonal Gesture"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvOverlayStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Overlay permission: Unknown"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Service Toggle -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnServiceToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Service"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <!-- Debug Mode Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Debug Mode (visible overlay)"
                android:textSize="14sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchDebug"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp" />

        <!-- Target App Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Target App"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvSelectedApp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No app selected"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectApp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select"
                style="@style/Widget.Material3.Button.TonalButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear"
                android:visibility="gone"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Trigger Position -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trigger Position"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerPosition"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp" />

        <!-- Trigger Area Size -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trigger Area Size"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Width"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/seekbarWidth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="150"
                android:progress="80" />

            <TextView
                android:id="@+id/tvWidthValue"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="80 dp"
                android:textSize="14sp"
                android:gravity="end" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Height"
                android:textSize="14sp" />

            <SeekBar
                android:id="@+id/seekbarHeight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="200"
                android:progress="120" />

            <TextView
                android:id="@+id/tvHeightValue"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="120 dp"
                android:textSize="14sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Swipe Threshold -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Swipe Sensitivity (lower = easier to trigger)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <SeekBar
                android:id="@+id/seekbarThreshold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="250"
                android:progress="150" />

            <TextView
                android:id="@+id/tvThresholdValue"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="150 px"
                android:textSize="14sp"
                android:gravity="end" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Swipe up from the trigger area to open the selected app. Enable Debug Mode to see the trigger areas as red overlays."
            android:textSize="12sp"
            android:textColor="#666666"
            android:lineSpacingExtra="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View logs: adb logcat -s GestureOverlay"
            android:textSize="12sp"
            android:textColor="#0066CC"
            android:textStyle="italic"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>